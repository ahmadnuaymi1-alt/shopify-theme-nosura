    },
    {
      "type": "header",
      "content": "Feature 2"
    },
    {
      "type": "image_picker",
      "id": "feature_2_icon",
      "label": "Icon"
    },
    {
      "type": "inline_richtext",
      "id": "feature_2_heading",
      "label": "Heading",
      "default": "Fast Shipping"
    },
    {
      "type": "richtext",
      "id": "feature_2_body",
      "label": "Body text",
