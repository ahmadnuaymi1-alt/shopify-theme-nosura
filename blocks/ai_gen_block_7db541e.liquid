      "type": "font_picker",
      "id": "body_font",
      "label": "Body font",
      "default": "inter_n4"
    },
    {
      "type": "range",
      "id": "body_font_size",
      "label": "Body size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body color",
      "default": "#666666"
    }
  ],
  "presets": [
    {
      "name": "Product features"
    }
  ]
