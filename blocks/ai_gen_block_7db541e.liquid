      "type": "image_picker",
      "id": "feature_3_icon",
      "label": "Icon"
    },
    {
      "type": "inline_richtext",
      "id": "feature_3_heading",
      "label": "Heading",
      "default": "Easy Returns"
    },
    {
      "type": "richtext",
      "id": "feature_3_body",
      "label": "Body text",
      "default": "<p>30-day hassle-free return policy</p>"
    },
    {
      "type": "header",
      "content": "Feature 4"
    },
    {
      "type": "image_picker",
      "id": "feature_4_icon",
      "label": "Icon"
    },
    {
      "type": "inline_richtext",
      "id": "feature_4_heading",
      "label": "Heading",
      "default": "Secure Payment"
    },
    {
      "type": "richtext",
      "id": "feature_4_body",
      "label": "Body text",
      "default": "<p>Your payment information is always protected</p>"
