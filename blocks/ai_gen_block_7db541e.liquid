{% doc %}
  @prompt
    Create a centered Product Features section with a large featured product image in the middle and four feature items, two on each side.
    
    Layout & positioning
    
    The featured image must be centered
    
    Feature items must be visually closer to the image, not pushed toward the page edges
    
    Icons must sit between the text and the image (icon nearest the image)
    
    Allow adjusting horizontal distance between features and the image
    
    Allow adjusting vertical spacing between feature items (desktop and mobile separately)
    
    Allow editing overall desktop section width
    
    Allow editing text container width and maximum text line length (avoid narrow text columns)
    
    Image controls
    
    Allow selecting a product image by index (e.g. 2nd image from product gallery)
    
    If the selected image doesn’t exist, allow a fallback product image selection
    
    Allow choosing the fallback image index
    
    Allow adjusting featured image size
    
    Keep image vertically centered relative to features
    
    Feature items (4 total)
    Each feature must include:
    
    Circular icon container
    
    Custom icon image upload
    
    Adjustable icon size inside the circle
    
    Feature heading (supports dynamic source / metafield)
    
    Feature body text (supports dynamic source / metafield)
    
    Typography controls for heading and body (font, size, weight)
    
    Spacing controls
    
    Slider for:
    
    Vertical spacing between feature blocks
    
    Horizontal spacing from features to image
    
    Icon-to-text spacing
    
    Separate mobile spacing controls
    
    Responsive behavior
    
    Maintain centered layout on mobile
    
    Allow mobile-specific vertical spacing
    
    Image can stack above features on mobile if needed
    
    Styling
    
    Clean, modern, minimal aesthetic
    
    No forced text wrapping
    
    Icons visually aligned and consistently sized
    
    Section must look balanced and symmetrical, allow me to use dynamic source for body text also. Allow me more vertical spacing between features. On mobile give me the option to put all features under the image. The heading size only goes up in 2s, allow me to choose a specific number like 19., Allow me the option to choose the circle size aswell as the icon size
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  assign selected_image_index = block.settings.featured_image_index | minus: 1
  assign fallback_image_index = block.settings.fallback_image_index | minus: 1
  
  if product.images[selected_image_index]
    assign featured_image = product.images[selected_image_index]
  elsif product.images[fallback_image_index]
    assign featured_image = product.images[fallback_image_index]
  else
    assign featured_image = product.featured_image
  endif
%}

{% style %}
  .ai-product-features-{{ai_gen_id}} {
    width: 100%;
    display: flex;
    justify-content: center;
    padding: 40px 20px;
  }

  .ai-product-features__container-{{ai_gen_id}} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: {{ block.settings.horizontal_spacing }}px;
  }

  .ai-product-features__side-{{ai_gen_id}} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.vertical_spacing_desktop }}px;
    flex: 0 0 auto;
  }

  .ai-product-features__image-container-{{ai_gen_id}} {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-features__image-wrapper-{{ai_gen_id}} {
    width: {{ block.settings.image_size }}px;
    height: {{ block.settings.image_size }}px;
    position: relative;
  }

  .ai-product-features__image-wrapper-{{ai_gen_id}} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 8px;
  }

  .ai-product-features__image-placeholder-{{ai_gen_id}} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
  }

  .ai-product-features__image-placeholder-{{ai_gen_id}} svg {
    width: 60%;
    height: 60%;
  }

  .ai-product-features__item-{{ai_gen_id}} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.icon_text_spacing }}px;
    max-width: {{ block.settings.text_container_width }}px;
  }

  .ai-product-features__side-{{ai_gen_id}}--left .ai-product-features__item-{{ai_gen_id}} {
    flex-direction: row-reverse;
    text-align: right;
  }

  .ai-product-features__side-{{ai_gen_id}}--right .ai-product-features__item-{{ai_gen_id}} {
    flex-direction: row;
    text-align: left;
  }

  .ai-product-features__icon-circle-{{ai_gen_id}} {
    flex-shrink: 0;
    width: {{ block.settings.icon_circle_size }}px;
    height: {{ block.settings.icon_circle_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.icon_circle_background }};
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid {{ block.settings.icon_circle_border }};
  }

  .ai-product-features__icon-{{ai_gen_id}} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    object-fit: contain;
  }

  .ai-product-features__icon-placeholder-{{ai_gen_id}} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    background-color: #e0e0e0;
    border-radius: 4px;
  }

  .ai-product-features__text-{{ai_gen_id}} {
    flex: 1;
    min-width: 0;
  }

  .ai-product-features__heading-{{ai_gen_id}} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_font_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 8px 0;
    line-height: 1.3;
    max-width: {{ block.settings.max_text_width }}ch;
    {% if block.settings.text_container_width %}
      word-wrap: break-word;
      overflow-wrap: break-word;
    {% endif %}
  }

  .ai-product-features__side-{{ai_gen_id}}--left .ai-product-features__heading-{{ai_gen_id}} {
    margin-left: auto;
  }

  .ai-product-features__body-{{ai_gen_id}} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: {{ block.settings.body_font_size }}px;
    color: {{ block.settings.body_color }};
    margin: 0;
    line-height: 1.5;
    max-width: {{ block.settings.max_text_width }}ch;
    {% if block.settings.text_container_width %}
      word-wrap: break-word;
      overflow-wrap: break-word;
    {% endif %}
  }

  .ai-product-features__side-{{ai_gen_id}}--left .ai-product-features__body-{{ai_gen_id}} {
    margin-left: auto;
  }

  .ai-product-features__all-features-{{ai_gen_id}} {
    display: none;
  }

  @media screen and (max-width: 989px) {
    .ai-product-features__container-{{ai_gen_id}} {
      flex-direction: column;
      gap: 40px;
    }

    .ai-product-features__side-{{ai_gen_id}} {
      width: 100%;
      gap: {{ block.settings.vertical_spacing_mobile }}px;
    }

    .ai-product-features__item-{{ai_gen_id}} {
      max-width: 100%;
    }

    .ai-product-features__side-{{ai_gen_id}}--left .ai-product-features__item-{{ai_gen_id}},
    .ai-product-features__side-{{ai_gen_id}}--right .ai-product-features__item-{{ai_gen_id}} {
      flex-direction: row;
      text-align: left;
    }

    .ai-product-features__side-{{ai_gen_id}}--left .ai-product-features__heading-{{ai_gen_id}},
    .ai-product-features__side-{{ai_gen_id}}--left .ai-product-features__body-{{ai_gen_id}} {
      margin-left: 0;
    }

    .ai-product-features__image-wrapper-{{ai_gen_id}} {
      width: {{ block.settings.image_size | times: 0.8 }}px;
      height: {{ block.settings.image_size | times: 0.8 }}px;
    }

    {% if block.settings.mobile_layout == 'stacked' %}
      .ai-product-features__side-{{ai_gen_id}} {
        display: none;
      }

      .ai-product-features__all-features-{{ai_gen_id}} {
        display: flex;
        flex-direction: column;
        gap: {{ block.settings.vertical_spacing_mobile }}px;
        width: 100%;
      }
    {% endif %}
  }
{% endstyle %}

<div class="ai-product-features-{{ai_gen_id}}" {{ block.shopify_attributes }}>
  <div class="ai-product-features__container-{{ai_gen_id}}">
    <div class="ai-product-features__side-{{ai_gen_id}} ai-product-features__side-{{ai_gen_id}}--left">
      {% for i in (1..2) %}
        {% liquid
          assign icon_key = 'feature_' | append: i | append: '_icon'
          assign heading_key = 'feature_' | append: i | append: '_heading'
          assign body_key = 'feature_' | append: i | append: '_body'
          
          assign feature_icon = block.settings[icon_key]
          assign feature_heading = block.settings[heading_key]
          assign feature_body = block.settings[body_key]
        %}
        
        <div class="ai-product-features__item-{{ai_gen_id}}">
          <div class="ai-product-features__icon-circle-{{ai_gen_id}}">
            {% if feature_icon %}
              <img 
                src="{{ feature_icon | image_url: width: 200 }}" 
                alt="{{ feature_heading }}"
                class="ai-product-features__icon-{{ai_gen_id}}"
                loading="lazy"
                width="200"
                height="200"
              >
            {% else %}
              <div class="ai-product-features__icon-placeholder-{{ai_gen_id}}"></div>
            {% endif %}
          </div>
          <div class="ai-product-features__text-{{ai_gen_id}}">
            {% if feature_heading != blank %}
              <h3 class="ai-product-features__heading-{{ai_gen_id}}">{{ feature_heading }}</h3>
            {% endif %}
            {% if feature_body != blank %}
              <div class="ai-product-features__body-{{ai_gen_id}}">{{ feature_body }}</div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

    <div class="ai-product-features__image-container-{{ai_gen_id}}">
      <div class="ai-product-features__image-wrapper-{{ai_gen_id}}">
        {% if featured_image %}
          <img
            src="{{ featured_image | image_url: width: 1000 }}"
            alt="{{ featured_image.alt | escape }}"
            loading="lazy"
            width="{{ featured_image.width }}"
            height="{{ featured_image.height }}"
          >
        {% else %}
          <div class="ai-product-features__image-placeholder-{{ai_gen_id}}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-product-features__side-{{ai_gen_id}} ai-product-features__side-{{ai_gen_id}}--right">
      {% for i in (3..4) %}
        {% liquid
          assign icon_key = 'feature_' | append: i | append: '_icon'
          assign heading_key = 'feature_' | append: i | append: '_heading'
          assign body_key = 'feature_' | append: i | append: '_body'
          
          assign feature_icon = block.settings[icon_key]
          assign feature_heading = block.settings[heading_key]
          assign feature_body = block.settings[body_key]
        %}
        
        <div class="ai-product-features__item-{{ai_gen_id}}">
          <div class="ai-product-features__icon-circle-{{ai_gen_id}}">
            {% if feature_icon %}
              <img 
                src="{{ feature_icon | image_url: width: 200 }}" 
                alt="{{ feature_heading }}"
                class="ai-product-features__icon-{{ai_gen_id}}"
                loading="lazy"
                width="200"
                height="200"
              >
            {% else %}
              <div class="ai-product-features__icon-placeholder-{{ai_gen_id}}"></div>
            {% endif %}
          </div>
          <div class="ai-product-features__text-{{ai_gen_id}}">
            {% if feature_heading != blank %}
              <h3 class="ai-product-features__heading-{{ai_gen_id}}">{{ feature_heading }}</h3>
            {% endif %}
            {% if feature_body != blank %}
              <div class="ai-product-features__body-{{ai_gen_id}}">{{ feature_body }}</div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

    <div class="ai-product-features__all-features-{{ai_gen_id}}">
      {% for i in (1..4) %}
        {% liquid
          assign icon_key = 'feature_' | append: i | append: '_icon'
          assign heading_key = 'feature_' | append: i | append: '_heading'
          assign body_key = 'feature_' | append: i | append: '_body'
          
          assign feature_icon = block.settings[icon_key]
          assign feature_heading = block.settings[heading_key]
          assign feature_body = block.settings[body_key]
        %}
        
        <div class="ai-product-features__item-{{ai_gen_id}}">
          <div class="ai-product-features__icon-circle-{{ai_gen_id}}">
            {% if feature_icon %}
              <img 
                src="{{ feature_icon | image_url: width: 200 }}" 
                alt="{{ feature_heading }}"
                class="ai-product-features__icon-{{ai_gen_id}}"
                loading="lazy"
                width="200"
                height="200"
              >
            {% else %}
              <div class="ai-product-features__icon-placeholder-{{ai_gen_id}}"></div>
            {% endif %}
          </div>
          <div class="ai-product-features__text-{{ai_gen_id}}">
            {% if feature_heading != blank %}
              <h3 class="ai-product-features__heading-{{ai_gen_id}}">{{ feature_heading }}</h3>
            {% endif %}
            {% if feature_body != blank %}
              <div class="ai-product-features__body-{{ai_gen_id}}">{{ feature_body }}</div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product features",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 90
    },
    {
      "type": "range",
      "id": "text_container_width",
      "label": "Text container width",
      "min": 200,
      "max": 500,
      "step": 20,
      "unit": "px",
      "default": 300
    },
    {
      "type": "range",
      "id": "max_text_width",
      "label": "Max text line length",
      "min": 30,
      "max": 80,
      "step": 5,
      "unit": "ch",
      "default": 50
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile layout",
      "options": [
        {
          "value": "split",
          "label": "Split (2 features per side)"
        },
        {
          "value": "stacked",
          "label": "Stacked (all features below image)"
        }
      ],
      "default": "split"
    },
    {
      "type": "header",
      "content": "Featured image"
    },
    {
      "type": "range",
      "id": "featured_image_index",
      "label": "Product image index",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "fallback_image_index",
      "label": "Fallback image index",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "image_size",
      "label": "Image size",
      "min": 200,
      "max": 600,
      "step": 20,
      "unit": "px",
      "default": 400
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "horizontal_spacing",
      "label": "Horizontal spacing",
      "min": 20,
      "max": 150,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "vertical_spacing_desktop",
      "label": "Vertical spacing (desktop)",
      "min": 20,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "vertical_spacing_mobile",
      "label": "Vertical spacing (mobile)",
      "min": 15,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "icon_text_spacing",
      "label": "Icon to text spacing",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Icon style"
    },
    {
      "type": "range",
      "id": "icon_circle_size",
      "label": "Circle size",
      "min": 60,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "icon_circle_background",
      "label": "Circle background",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "icon_circle_border",
      "label": "Circle border",
      "default": "#e0e0e0"
    },
    {
      "type": "header",
      "content": "Feature 1"
    },
    {
      "type": "image_picker",
      "id": "feature_1_icon",
      "label": "Icon"
    },
    {
      "type": "inline_richtext",
