{% doc %}
  @prompt
    Create me a sliding image carousel like this. Give me the option to choose the size of my images. Keep the carousel smoothly autoplaying, not autoplaying 1 image at a time. Don't stop autoplaying when hovered over. Let me choose how many images I want to display. Also give me the option to add above and below section spacing, Well done but it isn't auto sliding, Allow me to choose my desktop width for the section, Please allow the carousel to be of full width of the page
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  assign total_item_width = block.settings.image_width | plus: block.settings.image_gap
  assign total_distance = total_item_width | times: block.settings.image_count
%}

{% style %}
  .ai-carousel-wrapper-{{ ai_gen_id }} {
    width: 100%;
    padding-top: {{ block.settings.spacing_top }}px;
    padding-bottom: {{ block.settings.spacing_bottom }}px;
  }

  .ai-carousel-container-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-carousel-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.image_gap }}px;
    animation: ai-carousel-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
    will-change: transform;
  }

  .ai-carousel-item-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.image_width }}px;
    height: {{ block.settings.image_height }}px;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-carousel-item-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-carousel-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-carousel-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  @keyframes ai-carousel-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-{{ total_distance }}px);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-carousel-item-{{ ai_gen_id }} {
      width: {{ block.settings.image_width | times: 0.7 }}px;
      height: {{ block.settings.image_height | times: 0.7 }}px;
    }
  }
{% endstyle %}

<div class="ai-carousel-wrapper-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <sliding-carousel-{{ ai_gen_id }} class="ai-carousel-container-{{ ai_gen_id }}">
    <div class="ai-carousel-track-{{ ai_gen_id }}">
      {% for i in (1..block.settings.image_count) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign image = block.settings[image_key]
        %}
        <div class="ai-carousel-item-{{ ai_gen_id }}">
          {% if image %}
            <img
              src="{{ image | image_url: width: 800 }}"
              alt="{{ image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.image_width }}"
              height="{{ block.settings.image_height }}"
            >
          {% else %}
            <div class="ai-carousel-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      {% endfor %}
      {% for i in (1..block.settings.image_count) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign image = block.settings[image_key]
        %}
        <div class="ai-carousel-item-{{ ai_gen_id }}">
          {% if image %}
            <img
              src="{{ image | image_url: width: 800 }}"
              alt="{{ image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.image_width }}"
              height="{{ block.settings.image_height }}"
            >
          {% else %}
            <div class="ai-carousel-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </sliding-carousel-{{ ai_gen_id }}>
</div>

<script>
  (function() {
    class SlidingCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-carousel-track-{{ ai_gen_id }}');
      }
    }

    customElements.define('sliding-carousel-{{ ai_gen_id }}', SlidingCarousel{{ ai_gen_id }});
  })();
</script>

