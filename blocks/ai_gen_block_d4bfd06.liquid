{% doc %}
  @prompt
    Create me a sliding image carousel like this. Give me the option to choose the size of my images. Keep the carousel smoothly autoplaying, not autoplaying 1 image at a time. Don't stop autoplaying when hovered over. Let me choose how many images I want to display. Also give me the option to add above and below section spacing, Well done but it isn't auto sliding, Allow me to choose my desktop width for the section, Please allow the carousel to be of full width of the page. There was previously an issue where sometimes an image takes a while to show after scrolling. Please make sure this doesn't happen., it's not scrolling
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-carousel-container-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    overflow: hidden;
    padding-top: {{ block.settings.spacing_top }}px;
    padding-bottom: {{ block.settings.spacing_bottom }}px;
  }

  .ai-carousel-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    overflow: hidden;
  }

  .ai-carousel-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.image_gap }}px;
    width: max-content;
  }

  .ai-carousel-image-wrapper-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.image_width }}px;
    height: {{ block.settings.image_height }}px;
  }

  .ai-carousel-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: block;
  }

  .ai-carousel-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-carousel-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  @media screen and (max-width: 749px) {
    .ai-carousel-wrapper-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-carousel-image-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.image_width | times: 0.7 }}px;
      height: {{ block.settings.image_height | times: 0.7 }}px;
    }
  }
{% endstyle %}

<image-carousel-{{ ai_gen_id }}
  class="ai-carousel-container-{{ ai_gen_id }}"
  data-speed="{{ block.settings.scroll_speed }}"
  data-image-width="{{ block.settings.image_width }}"
  data-gap="{{ block.settings.image_gap }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-carousel-wrapper-{{ ai_gen_id }}">
    <div class="ai-carousel-track-{{ ai_gen_id }}">
      {% for i in (1..block.settings.image_count) %}
        {% assign image_key = 'image_' | append: i %}
        {% assign image = block.settings[image_key] %}
        
        <div class="ai-carousel-image-wrapper-{{ ai_gen_id }}">
          {% if image %}
            <img
              src="{{ image | image_url: width: 800 }}"
              alt="{{ image.alt | escape }}"
              loading="eager"
              width="{{ block.settings.image_width }}"
              height="{{ block.settings.image_height }}"
              class="ai-carousel-image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-carousel-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      {% endfor %}

      {% for i in (1..block.settings.image_count) %}
        {% assign image_key = 'image_' | append: i %}
        {% assign image = block.settings[image_key] %}
        
        <div class="ai-carousel-image-wrapper-{{ ai_gen_id }}">
          {% if image %}
            <img
              src="{{ image | image_url: width: 800 }}"
              alt="{{ image.alt | escape }}"
              loading="eager"
              width="{{ block.settings.image_width }}"
              height="{{ block.settings.image_height }}"
              class="ai-carousel-image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-carousel-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</image-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.scrollPosition = 0;
        this.animationId = null;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-carousel-track-{{ ai_gen_id }}');
        this.speed = parseFloat(this.dataset.speed) || 30;
        this.imageWidth = parseFloat(this.dataset.imageWidth) || 300;
        this.gap = parseFloat(this.dataset.gap) || 20;
        
        this.preloadImages();
        this.startScrolling();
      }

      preloadImages() {
        const images = this.querySelectorAll('.ai-carousel-image-{{ ai_gen_id }}');
        images.forEach((img) => {
          if (img.complete) {
            return;
          }
          const tempImg = new Image();
          tempImg.src = img.src;
        });
      }

      startScrolling() {
        const itemWidth = this.imageWidth + this.gap;
        const totalWidth = itemWidth * (this.track.children.length / 2);
        const pixelsPerSecond = totalWidth / this.speed;
        const pixelsPerFrame = pixelsPerSecond / 60;

        const animate = () => {
          this.scrollPosition += pixelsPerFrame;
          
          if (this.scrollPosition >= totalWidth) {
            this.scrollPosition = 0;
          }
          
          this.track.style.transform = `translateX(-${this.scrollPosition}px)`;
          this.animationId = requestAnimationFrame(animate);
        };

        this.animationId = requestAnimationFrame(animate);
      }

      disconnectedCallback() {
        if (this.animationId) {
          cancelAnimationFrame(this.animationId);
        }
      }
    }

    customElements.define('image-carousel-{{ ai_gen_id }}', ImageCarousel{{ ai_gen_id }});
  })();
</script>

